---
import Base from '../layouts/Base.astro';
import { Icon } from 'astro-icon/components';
---

<Base
  title="Vielen Dank – Auto Wiss"
  path="/danke.html"
  noindex={true}
  header="minimal"
>
  <style slot="head">
    body { display: flex; flex-direction: column; min-height: 100vh; }
    .ty { flex: 1; display: grid; place-items: center; text-align: center; padding: clamp(3rem, 8vw, 6rem) 0; position: relative; }
    .ty__glow { position: absolute; inset: 0; background: radial-gradient(circle at 50% 30%, rgba(228,251,80,0.12), transparent 55%); pointer-events: none; }
    .ty .wrap { position: relative; max-width: 640px; }
    .ty__mark { width: 92px; height: 92px; margin: 0 auto 2rem; border-radius: 50%; background: var(--acid); color: var(--ink); display: grid; place-items: center; box-shadow: 0 0 0 10px rgba(228,251,80,0.12); }
    .ty__mark .ico { font-size: 46px; }
    .ty .eyebrow { display: block; margin-bottom: 1rem; }
    .ty h1 { margin-bottom: 1.2rem; }
    .ty p { color: #cfd4de; font-size: var(--t-lead); max-width: 44ch; margin: 0 auto 2.2rem; }
    .ty__acts { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; }
  </style>

  <main class="ty">
    <div class="ty__glow"></div>
    <div class="wrap">
      <div class="ty__mark"><Icon class="ico" name="tabler:check" /></div>
      <span class="eyebrow">Anfrage gesendet</span>
      <h1 class="h-hero">Vielen Dank!</h1>
      <p>Ihre Offerte-Anfrage ist bei uns eingegangen. Wir melden uns so schnell wie möglich —
        meist noch am selben Tag. Für dringende Fälle erreichen Sie uns rund um die Uhr per Telefon.</p>
      <div class="ty__acts">
        <a href="index.html" class="btn">Zurück zur Startseite</a>
        <a href="tel:+41789008888" class="btn btn--ghost">078 900 88 88 anrufen</a>
      </div>
    </div>
  </main>
</Base>
