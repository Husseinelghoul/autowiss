---
import Base from '../layouts/Base.astro';
import { Icon } from 'astro-icon/components';
import { locations } from '../data/locations.js';
---

<Base
  title="Auto Wiss – Autoankauf, Export & Verkauf in der Schweiz"
  description="Auto Wiss kauft Ihr Auto in jedem Zustand – sofort Bargeld, wir kommen zu Ihnen und übernehmen die Ab- und Ummeldung. Autoankauf, Export und Verkauf in der ganzen Schweiz, 24/7."
  path="/"
  ogTitle="Auto Wiss – Autoankauf, Export & Verkauf in der Schweiz"
  ogDescription="Wir kaufen Ihr Auto in jedem Zustand, zahlen sofort Bargeld und übernehmen die Formalitäten. 24/7 erreichbar."
  header="home"
  businessSchema={true}
>
  <style slot="head">
    /* ---------- Page-specific: homepage sections ---------- */
    .ico { font-size: 1em; }

    /* Hero */
    .hero { position: relative; padding: clamp(2.5rem, 6vw, 4.5rem) 0 0; }
    .hero__glow { position: absolute; top: -8%; right: -6%; width: 60vw; height: 60vw; max-width: 760px; max-height: 760px; background: radial-gradient(circle, rgba(228,251,80,0.15), transparent 62%); pointer-events: none; z-index: 0; }
    .hero__grid { position: relative; z-index: 1; display: grid; grid-template-columns: 1.35fr 0.65fr; gap: 3rem; align-items: end; }
    .hero__grid > * { min-width: 0; }
    .hero h1, .hero__sub { overflow-wrap: break-word; }
    .hero .eyebrow { display: inline-block; margin-bottom: 1.5rem; }
    .hero h1 .out { color: transparent; -webkit-text-stroke: 1.6px var(--paper); }
    .hero__sub { max-width: 44ch; margin: 1.7rem 0 2.1rem; }
    .hero__sub b { color: var(--paper); font-weight: 700; }
    .hero__actions { display: flex; flex-wrap: wrap; gap: 0.9rem; }
    .hero__trust { display: flex; flex-wrap: wrap; gap: 0.9rem 1.8rem; margin-top: 2.4rem; padding-top: 1.5rem; border-top: 1px solid var(--line); }
    .hero__trust div { display: inline-flex; align-items: center; gap: 0.55rem; font-family: var(--f-label); font-size: 0.76rem; text-transform: uppercase; letter-spacing: 0.04em; color: #cfd4de; }
    .hero__trust .ico { color: var(--acid); }

    .plate { background: var(--ink-2); border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden; }
    .plate__img { position: relative; aspect-ratio: 4 / 3.3; }
    .plate__img img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(1) contrast(1.05) brightness(0.92); transition: filter 0.6s var(--ease), transform 0.9s var(--ease); }
    .plate:hover .plate__img img { filter: grayscale(0); transform: scale(1.04); }
    .plate__scrim { position: absolute; inset: 0; z-index: 2; background: linear-gradient(180deg, transparent 42%, rgba(14,26,48,0.88)); }
    .plate__tag { position: absolute; top: 12px; left: 12px; z-index: 3; font-family: var(--f-label); font-weight: 700; font-size: 0.68rem; letter-spacing: 0.12em; background: var(--acid); color: var(--ink); padding: 4px 10px; border-radius: 3px; }
    .plate__stat { position: absolute; left: 16px; bottom: 14px; z-index: 3; }
    .plate__stat b { font-family: var(--f-display); font-size: 2.7rem; color: var(--acid); display: block; line-height: 0.9; }
    .plate__stat span { font-family: var(--f-label); font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.1em; color: #cfd4de; }
    .plate__foot { display: flex; align-items: center; justify-content: space-between; padding: 0.85rem 1rem; font-family: var(--f-label); font-size: 0.7rem; letter-spacing: 0.08em; color: var(--steel); }
    .plate__foot .ch { border: 1px solid var(--line); padding: 3px 8px; border-radius: 3px; color: var(--paper); }
    .plate__foot .ch b { color: var(--acid); }

    /* Marquee band */
    .band { margin-top: clamp(2.5rem, 5vw, 4rem); border-block: 1px solid var(--line); overflow: hidden; white-space: nowrap; }
    .band__track { display: inline-flex; align-items: center; animation: marq 30s linear infinite; will-change: transform; }
    .band:hover .band__track { animation-play-state: paused; }
    .band__track b { font-family: var(--f-display); font-size: clamp(1.5rem, 3.2vw, 2.7rem); text-transform: uppercase; padding: 0.65rem 1.4rem; color: var(--paper); }
    .band__track b:nth-child(even) { color: transparent; -webkit-text-stroke: 1.3px var(--steel); }
    .band__track i { color: var(--acid); font-style: normal; font-size: 0.7em; padding: 0 0.2rem; }
    @keyframes marq { to { transform: translateX(-50%); } }

    /* Value grid */
    .vgrid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--line-ink); border: 1px solid var(--line-ink); border-radius: var(--radius); overflow: hidden; }
    .vcard { background: var(--paper); padding: 2rem 1.6rem; min-height: 210px; display: flex; flex-direction: column; gap: 1.4rem; transition: background 0.3s, color 0.3s; }
    .vcard__n { font-family: var(--f-label); font-size: 0.78rem; letter-spacing: 0.1em; color: var(--steel-2); }
    .vcard h3 { font-family: var(--f-body); font-weight: 800; font-size: 1.2rem; line-height: 1.1; margin-bottom: 0.45rem; }
    .vcard p { font-size: 0.92rem; color: var(--steel-2); }
    .vcard:hover { background: var(--ink); color: var(--paper); }
    .vcard:hover .vcard__n { color: var(--acid); }
    .vcard:hover p { color: #b8c0cf; }

    /* Services */
    .svc { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.3rem; }
    .scard { position: relative; overflow: hidden; border-radius: var(--radius); min-height: 330px; display: flex; flex-direction: column; justify-content: flex-end; padding: 2rem; isolation: isolate; border: 1px solid var(--line); }
    .scard .media { position: absolute; inset: 0; z-index: -2; }
    .scard .media img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(1) brightness(0.4) contrast(1.05); transition: transform 1s var(--ease), filter 0.6s; }
    .scard::before { content: ""; position: absolute; inset: 0; z-index: -1; background: linear-gradient(180deg, rgba(14,26,48,0.1), rgba(14,26,48,0.92)); }
    .scard:hover .media img { transform: scale(1.06); filter: grayscale(0.35) brightness(0.5); }
    .scard__no { position: absolute; top: 1.4rem; right: 1.6rem; font-family: var(--f-label); color: var(--acid); font-size: 0.78rem; letter-spacing: 0.1em; }
    .scard h3 { margin-bottom: 0.55rem; }
    .scard p { max-width: 42ch; color: #d5dae2; font-size: 0.94rem; }
    .scard .more { margin-top: 1.1rem; display: inline-flex; gap: 0.4rem; align-items: center; font-family: var(--f-label); font-size: 0.76rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--acid); }
    .scard .more .arw { transition: transform 0.25s var(--ease); }
    .scard:hover .more .arw { transform: translateX(4px); }
    .scard.wide { grid-column: span 2; min-height: 250px; }

    /* Process */
    .steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.4rem; counter-reset: s; }
    .step { border-top: 3px solid var(--ink); padding-top: 1.3rem; position: relative; }
    .step__n { font-family: var(--f-display); font-size: clamp(3.2rem, 8vw, 6rem); line-height: 0.8; color: var(--ink); }
    .step__n::before { counter-increment: s; content: "0" counter(s); }
    .step h3 { font-family: var(--f-body); font-weight: 800; font-size: 1.35rem; margin: 0.5rem 0 0.4rem; line-height: 1.1; }
    .step p { color: var(--steel-2); max-width: 34ch; }
    .step .badge { position: absolute; top: 1.1rem; right: 0; font-family: var(--f-label); font-size: 0.68rem; background: var(--ink); color: var(--acid); padding: 3px 9px; border-radius: 3px; }

    /* Stats */
    .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--line); border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden; }
    .stat { padding: 2.3rem 1.5rem; background: var(--ink); }
    .stat b { font-family: var(--f-display); font-size: clamp(2.8rem, 5.5vw, 4.4rem); color: var(--paper); display: block; line-height: 0.85; }
    .stat b .s { color: var(--acid); }
    .stat span { font-family: var(--f-label); font-size: 0.74rem; text-transform: uppercase; letter-spacing: 0.09em; color: var(--steel); display: block; margin-top: 0.7rem; }

    /* Testimonials */
    .tgrid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.3rem; }
    .tcard { border: 1px solid var(--line-ink); border-radius: var(--radius); padding: 1.9rem; background: #fff; display: flex; flex-direction: column; gap: 1rem; }
    .stars { display: inline-flex; gap: 3px; color: var(--ink); }
    .stars .ico { font-size: 17px; }
    .tcard p { font-size: 1rem; color: #26261f; flex-grow: 1; }
    .who { display: flex; align-items: center; gap: 0.9rem; margin-top: 0.4rem; }
    .who .media { width: 46px; height: 46px; border-radius: 50%; flex: 0 0 auto; border: 2px solid var(--ink); }
    .who .media img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(1); }
    .who b { display: block; font-weight: 800; }
    .who span { font-family: var(--f-label); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--steel-2); }

    /* Partners — full-colour logos on white, contained (not cropped) */
    .partners { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.3rem; }
    .pcard { display: flex; align-items: center; gap: 1.3rem; background: #fff; border: 1px solid var(--line-ink); border-radius: var(--radius); padding: 1.4rem 1.6rem; transition: transform 0.3s var(--ease), border-color 0.3s, box-shadow 0.3s; }
    .pcard:hover { transform: translateY(-4px); border-color: transparent; box-shadow: 0 14px 30px rgba(14,26,48,0.12); }
    .pcard__logo { width: 84px; height: 60px; flex: 0 0 auto; display: grid; place-items: center; }
    .pcard__logo img { max-width: 100%; max-height: 100%; width: auto; height: auto; object-fit: contain; }
    .pcard b { font-family: var(--f-body); font-weight: 800; font-size: 1.05rem; display: block; }
    .pcard span { font-family: var(--f-label); font-size: 0.7rem; color: var(--steel-2); text-transform: uppercase; letter-spacing: 0.05em; }

    /* CTA */
    .cta { background: var(--acid); color: var(--ink); }
    .cta__in { display: grid; grid-template-columns: 1.35fr 1fr; gap: 2.5rem; align-items: center; }
    .cta .eyebrow { color: rgba(14,26,48,0.55); display: block; margin-bottom: 1rem; }
    .cta h2 { color: var(--ink); }
    .cta p { max-width: 40ch; margin-top: 1rem; font-weight: 600; }
    .cta__acts { display: flex; flex-direction: column; gap: 1rem; align-items: flex-start; }
    .cta__acts .btn { width: 100%; }
    .cta .phone { font-family: var(--f-display); font-size: clamp(1.9rem, 3.6vw, 3rem); display: inline-flex; align-items: center; gap: 0.55rem; color: var(--ink); }
    .cta .phone .ico { font-size: 0.8em; }
    .cta .mailto { font-family: var(--f-label); font-weight: 700; font-size: 0.85rem; }

    /* Standorte (locations) */
    /* Anton is wide; give this heading room so long words wrap whole, not mid-word */
    #standorte .sec-head__t { max-width: 34rem; }
    #standorte .sec-head h2 { max-width: none; }
    .locs { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.3rem; }
    .loc { background: var(--ink-2); border: 1px solid var(--line); border-radius: var(--radius); padding: 2rem; display: flex; flex-direction: column; gap: 0.7rem; transition: border-color 0.3s, transform 0.3s var(--ease); }
    .loc:hover { border-color: var(--acid); transform: translateY(-4px); }
    .loc__n { font-family: var(--f-label); font-size: 0.78rem; letter-spacing: 0.1em; color: var(--acid); }
    .loc h3 { display: flex; align-items: center; gap: 0.5rem; }
    .loc h3 .ico { color: var(--acid); font-size: 0.72em; }
    .loc__addr { font-style: normal; color: #cfd4de; line-height: 1.75; }
    .loc__meta { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--f-label); font-size: 0.76rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--steel); }
    .loc__meta .ico { color: var(--acid); }
    .loc__btn { align-self: flex-start; margin-top: 0.9rem; }

    @media (max-width: 900px) {
      .hero__grid { grid-template-columns: 1fr; }
      .hero__aside { max-width: 420px; }
      .vgrid { grid-template-columns: repeat(2, 1fr); }
      .svc { grid-template-columns: 1fr; }
      .scard.wide { grid-column: auto; }
      .steps { grid-template-columns: 1fr; }
      .stats { grid-template-columns: repeat(2, 1fr); }
      .tgrid { grid-template-columns: 1fr; }
      .partners { grid-template-columns: 1fr; }
      .cta__in { grid-template-columns: 1fr; }
      .locs { grid-template-columns: 1fr; }
    }
    @media (max-width: 560px) {
      .vgrid, .stats { grid-template-columns: 1fr; }
      .hero__actions { flex-direction: column; align-items: stretch; }
      .hero__actions .btn { width: 100%; }
      .hero__trust { gap: 0.7rem 1.4rem; }
      .hero__trust div { font-size: 0.72rem; }
      .scard { min-height: 280px; padding: 1.5rem; }
      .scard.wide { min-height: 220px; }
      .plate__stat b { font-size: 2.2rem; }
    }
  </style>

  <!-- Hero -->
  <section class="hero">
    <div class="hero__glow"></div>
    <div class="wrap hero__grid">
      <div class="hero__main">
        <span class="eyebrow rv">Autoankauf · Export · Geuensee</span>
        <h1 class="h-hero rv" style="transition-delay:.05s">
          Ihr Auto.<br />
          <span class="acid">Sofort Bargeld.</span><br />
          <span class="out">Überall.</span>
        </h1>
        <p class="hero__sub lead rv" style="transition-delay:.12s">
          Wir kaufen Ihr Auto in <b>jedem Zustand</b>, kommen zu Ihnen und zahlen bar vor Ort.
          Unfall, hohe Kilometer, defekt — egal. Die Ab- und Ummeldung übernehmen wir.
        </p>
        <div class="hero__actions rv" style="transition-delay:.18s">
          <a href="offerte.html" class="btn">Kostenlose Offerte <span class="arw">→</span></a>
          <a href="tel:+41789008888" class="btn btn--ghost">Jetzt anrufen</a>
        </div>
        <div class="hero__trust rv" style="transition-delay:.24s">
          <div><Icon class="ico" name="tabler:check" /> Bargeld vor Ort</div>
          <div><Icon class="ico" name="tabler:check" /> 24/7 erreichbar</div>
          <div><Icon class="ico" name="tabler:check" /> Ab- &amp; Ummeldung inklusive</div>
          <div><Icon class="ico" name="tabler:check" /> Ganze Schweiz</div>
        </div>
      </div>

      <aside class="hero__aside rv" style="transition-delay:.15s">
        <div class="plate">
          <div class="plate__img media">
            <span class="plate__tag">Bargeld sofort</span>
            <span class="plate__scrim"></span>
            <img src="/img/agreement.jpeg" width="640" height="528" alt="Handschlag beim sofortigen Autoankauf durch Auto Wiss" fetchpriority="high" decoding="async" />
            <div class="plate__stat"><b><span data-count="25" data-suffix="+">0</span></b><span>Jahre Erfahrung</span></div>
          </div>
          <div class="plate__foot">
            <span class="ch"><b>CH</b> · AUTO WISS</span>
            <span>LU · 6232</span>
          </div>
        </div>
      </aside>
    </div>

    <div class="band" aria-hidden="true">
      <div class="band__track">
        <b>Autoankauf</b><i>◆</i><b>Export</b><i>◆</i><b>Verkauf</b><i>◆</i><b>Oldtimer</b><i>◆</i><b>Import</b><i>◆</i><b>Bargeld</b><i>◆</i><b>Autoankauf</b><i>◆</i><b>Export</b><i>◆</i><b>Verkauf</b><i>◆</i><b>Oldtimer</b><i>◆</i><b>Import</b><i>◆</i><b>Bargeld</b><i>◆</i>
      </div>
    </div>
  </section>

  <!-- Why -->
  <section id="warum" class="pad light">
    <div class="wrap">
      <div class="sec-head rv">
        <div class="sec-head__t">
          <span class="eyebrow">Warum Auto Wiss</span>
          <h2 class="h-2">Problemloser Verkauf. Kein Papierkram.</h2>
        </div>
        <p>Sie organisieren nichts. Wir kommen, bewerten, kaufen und erledigen die Formalitäten — Sie halten das Bargeld in der Hand.</p>
      </div>
      <div class="vgrid rv">
        <div class="vcard"><span class="vcard__n">01</span><div><h3>Jeder Zustand</h3><p>Unfall, hohe Kilometer, Motorschaden oder defekt — wir kaufen ohne Fragen.</p></div></div>
        <div class="vcard"><span class="vcard__n">02</span><div><h3>Wir kommen zu Ihnen</h3><p>Kostenlose Abholung in der ganzen Schweiz. Sie müssen nirgends hinfahren.</p></div></div>
        <div class="vcard"><span class="vcard__n">03</span><div><h3>Bargeld vor Ort</h3><p>Fairer Preis, sofortige Auszahlung. Kein Warten, keine Ausreden.</p></div></div>
        <div class="vcard"><span class="vcard__n">04</span><div><h3>Formalitäten inklusive</h3><p>Ab- und Ummeldung übernehmen wir vollständig für Sie.</p></div></div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="leistungen" class="pad">
    <div class="wrap">
      <div class="sec-head rv">
        <div class="sec-head__t">
          <span class="eyebrow">Leistungen</span>
          <h2 class="h-2">Alles rund ums Auto</h2>
        </div>
        <p>Ankauf, Verkauf, Export und Import — ein Ansprechpartner für den gesamten Autohandel über Grenzen hinweg.</p>
      </div>
      <div class="svc">
        <article class="scard rv">
          <div class="media"><img src="/img/car-selling.jpeg" width="800" height="600" alt="Autoankauf bei Auto Wiss" loading="lazy" decoding="async" /></div>
          <span class="scard__no">01</span>
          <h3 class="h-3">Autoankauf</h3>
          <p>Wir kaufen Ihr Auto in jedem Zustand zum Bestpreis — sofort, unkompliziert und bar auf die Hand.</p>
          <a href="offerte.html" class="more">Offerte erhalten <span class="arw">→</span></a>
        </article>
        <article class="scard rv" style="transition-delay:.08s">
          <div class="media"><img src="/img/other-agents.jpeg" width="800" height="600" alt="Auto kaufen und verkaufen bei Auto Wiss" loading="lazy" decoding="async" /></div>
          <span class="scard__no">02</span>
          <h3 class="h-3">Verkauf &amp; Tausch</h3>
          <p>Grosse Auswahl an Neu- und Occasionsfahrzeugen. Probefahrten inklusive, Inzahlungnahme möglich.</p>
          <a href="#kontakt" class="more">Kontakt aufnehmen <span class="arw">→</span></a>
        </article>
        <article class="scard wide rv">
          <div class="media"><img src="/img/shipping.jpeg" width="1200" height="600" alt="Autoexport und -import von und in die Schweiz" loading="lazy" decoding="async" /></div>
          <span class="scard__no">03</span>
          <h3 class="h-3">Export &amp; Import</h3>
          <p>Autohandel über Grenzen hinweg — wir exportieren und importieren Fahrzeuge von und in die Schweiz und erledigen die gesamte Abwicklung.</p>
          <a href="#kontakt" class="more">Mehr erfahren <span class="arw">→</span></a>
        </article>
        <article class="scard wide rv" style="transition-delay:.08s">
          <div class="media"><img src="/img/vintage.jpeg" width="1200" height="600" alt="Oldtimer und Vintage-Autos kaufen und verkaufen" loading="lazy" decoding="async" /></div>
          <span class="scard__no">04</span>
          <h3 class="h-3">Oldtimer &amp; Vintage</h3>
          <p>Für Sammler und Enthusiasten: Wir kaufen und verkaufen Vintage-Autos und bringen Liebhaber zusammen.</p>
          <a href="#kontakt" class="more">Sprechen wir <span class="arw">→</span></a>
        </article>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section id="ablauf" class="pad light">
    <div class="wrap">
      <div class="sec-head rv">
        <div class="sec-head__t">
          <span class="eyebrow">Der Ablauf</span>
          <h2 class="h-2">In 3 Schritten zum Bargeld</h2>
        </div>
        <p>Vom ersten Kontakt bis zur Auszahlung — oft am selben Tag.</p>
      </div>
      <div class="steps rv">
        <div class="step">
          <div class="step__n"></div>
          <span class="badge">2 Min.</span>
          <h3>Offerte anfragen</h3>
          <p>Formular ausfüllen oder anrufen. Sie erhalten eine unverbindliche Preiseinschätzung.</p>
        </div>
        <div class="step">
          <div class="step__n"></div>
          <span class="badge">Kostenlos</span>
          <h3>Wir kommen zu Ihnen</h3>
          <p>Wir begutachten das Fahrzeug bei Ihnen vor Ort — schweizweit, zu Ihrer Wunschzeit.</p>
        </div>
        <div class="step">
          <div class="step__n"></div>
          <span class="badge">Sofort</span>
          <h3>Bargeld &amp; fertig</h3>
          <p>Fairer Preis, Auszahlung in bar, Ab- und Ummeldung erledigen wir. Sie sind sorgenfrei.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="pad">
    <div class="wrap">
      <div class="stats rv">
        <div class="stat"><b><span class="s" data-count="25">0</span></b><span>Jahre Erfahrung</span></div>
        <div class="stat"><b><span data-count="1500" data-suffix="+">0</span></b><span>Zufriedene Kunden</span></div>
        <div class="stat"><b><span data-count="5000" data-suffix="+">0</span></b><span>Abgeschlossene Deals</span></div>
        <div class="stat"><b><span class="s">24/7</span></b><span>Für Sie erreichbar</span></div>
      </div>
    </div>
  </section>

  <!-- Testimonials + Partners -->
  <section id="stimmen" class="pad light">
    <div class="wrap">
      <div class="sec-head rv">
        <div class="sec-head__t">
          <span class="eyebrow">Kundenstimmen</span>
          <h2 class="h-2">Was unsere Kunden sagen</h2>
        </div>
        <p>Echte Bewertungen von Verkäufern und Käufern aus der ganzen Schweiz.</p>
      </div>
      <div class="tgrid rv">
        <div class="tcard">
